# BitHub V2 — Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git — it is gitignored

# ── Gemini API ─────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── SSH / Database Server ──────────────────────────
DB_SSH_HOST=your_server_ip_here       # e.g. 192.168.1.x
DB_SSH_USER=your_ssh_username
DB_SSH_PASS=your_sudo_password
DB_NAME=questions
